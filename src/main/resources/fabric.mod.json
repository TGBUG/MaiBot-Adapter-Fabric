{
	"schemaVersion": 1,
	"id": "maibot-adapter",
	"version": "${version}",
	"name": "MaiBot-Adapter",
	"description": "WebSocket bridge between Minecraft server and MaiBot plugin",
	"authors": [
		"tgbug"
	],
	"contact": {
		"sources": "https://github.com/tgbug/MaiBot-Adapter-Fabric"
	},
	"license": "MIT",
	"icon": "assets/maibot-adapter/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"cn.tgbug.MaiBotAdapter"
		],
		"client": [
			"cn.tgbug.client.MaiBotAdapterClient"
		]
	},
	"mixins": [
		"maibot-adapter.mixins.json",
		{
			"config": "maibot-adapter.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": ">=26.1.0",
		"java": ">=21",
		"fabric-api": ">=0.102.0"
	}
}
